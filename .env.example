# FleetDB MCP Server — configuration template
# Copy to .env and edit as needed. The default values point at the local
# docker-compose Postgres instance.

DATABASE_URL=postgresql://fleet:fleet@localhost:5432/fleetdb

# Identifier recorded in the audit log for every write performed through
# this server. Set per client: "claude-desktop", "claude-code",
# "langgraph-agent", "mobilityops-crew", etc.
MCP_ACTOR=local-dev

# Hard cap on rows returned from query_read_only.
MCP_MAX_ROWS=500

# Postgres statement_timeout in milliseconds. Applied to every query.
MCP_QUERY_TIMEOUT_MS=5000

# Lifetime of a pending write proposal before confirm_write will reject it.
MCP_PROPOSAL_TTL_S=300
